<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Core Platform User</label>
    <description>Grants read and edit access to core platform custom fields on Account (Global Customer ID, Data Classification) and read access to the GlobalIdService Apex class.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <license>Salesforce</license>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Global_Customer_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Data_Classification__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <classAccesses>
        <apexClass>GlobalIdService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
